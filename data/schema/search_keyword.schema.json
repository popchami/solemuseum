{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kickxkick.local/schema/search_keyword.schema.json",
  "title": "KickxKick Search Keyword Data Master",
  "type": "object",
  "required": ["version", "updatedAt", "items"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "updatedAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["modelId", "keyword"],
        "additionalProperties": false,
        "properties": {
          "modelId": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "keyword": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
