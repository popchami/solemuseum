{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kickxkick.local/schema/brand.schema.json",
  "title": "KickxKick Brand Data Master",
  "type": "object",
  "required": ["version", "updatedAt", "items"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "updatedAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["brandId", "brandName", "tier", "isEnabled"],
        "additionalProperties": false,
        "properties": {
          "brandId": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "brandName": {"type": "string", "minLength": 1},
          "tier": {"type": "string", "enum": ["S", "A", "B", "C", "D", "E", "Planned"]},
          "isEnabled": {"type": "boolean"}
        }
      }
    }
  }
}
